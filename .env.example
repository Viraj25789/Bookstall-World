# Copy to .env for local dev. Never commit .env to git.

# Get this from Vercel → your project → Storage → your Postgres DB → .env.local tab
POSTGRES_URL=postgresql+psycopg2://user:password@host/dbname

# Any long random string — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-string

# One-time DB setup — visit /setup?token=THIS after first deploy
SETUP_TOKEN=replace-with-any-secret-word
